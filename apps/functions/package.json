    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^18.19.130",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "azure-functions-core-tools": "^4.x",
