# ============================================================
# JEE Main Paper Downloader — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# .env is git-ignored and will never be committed.
#
# Authentication: This pipeline uses Azure Entra ID (az login)
# for both Azure Blob Storage and PostgreSQL.
# No passwords or connection strings are needed.
# Just run: az login
# before executing the downloader.
# ============================================================

# --- Azure Blob Storage ---
# Storage account name (no secret — just the account name)
AZURE_STORAGE_ACCOUNT=<AZURE_STORAGE_ACCOUNT>

# Blob container where JEE PDFs will be uploaded
# PDFs are stored under: jeedata/{year}/{filename}
AZURE_STORAGE_CONTAINER=onlineresources

# --- PostgreSQL Database ---
# Azure-managed PostgreSQL host
DB_HOST=<DB_HOST>

DB_PORT=5432

DB_NAME=<DB_NAME>

# Your Entra ID (Azure AD) username for the database.
# Format: your-azure-ad-email@yourdomain.com
# Ensure your account has been granted access to the DB:
#   az postgres flexible-server ad-admin set ...
DB_USER=your-entra-username@yourdomain.com

# DB_PASSWORD is intentionally omitted.
# The pipeline fetches an Entra ID token automatically via az login.

# --- Download Settings (optional overrides) ---
# Local folder where PDFs are saved before blob upload.
# Defaults to pipelines/DataCollection/JEEMain/ if not set.
# DOWNLOAD_DIR=./JEEMain

# Years to download (comma-separated). Leave blank to download all available.
# YEARS_TO_DOWNLOAD=2023,2024
YEARS_TO_DOWNLOAD=
